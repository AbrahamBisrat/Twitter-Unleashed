{
    "manifest_version": 3,
    "name": "Twitter Unleashed",
    "version": "1.0.1",
    "description": "Persistent X.com enhancements — reply sorting, and more.",
    "icons": {
        "16": "icons/twitter.png",
        "48": "icons/twitter.png",
        "128": "icons/twitter.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/twitter.png",
            "48": "icons/twitter.png",
            "128": "icons/twitter.png"
        },
        "default_title": "Twitter Unleashed"
    },
    "permissions": [
        "storage",
        "webNavigation"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://x.com/*",
                "*://twitter.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}